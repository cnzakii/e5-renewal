# E5 Renewal configuration example
# Copy to ~/e5-renewal.yaml and edit; env vars take precedence (see .env.example)

server:
  host: ""
  port: 8080
  path_prefix: ""
  # tls_cert: /certs/fullchain.pem
  # tls_key: /certs/privkey.pem

database:
  path: "data/e5.db"

security:
  jwt_secret: "change-me-to-a-random-64-char-string"
  encryption_key: "change-me-to-a-random-string"
  # login_key: ""  # Auto-generated if empty

scheduler:
  min_hours: 2
  max_hours: 6
  endpoints_min: 3
  endpoints_max: 8
  realistic_timing: false
